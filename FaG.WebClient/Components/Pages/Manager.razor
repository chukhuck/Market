@page "/manager"
@inject IStatisticsService StatisticsService
@using FaG.WebClient.Services
@rendermode InteractiveServer

<PageTitle>Manager</PageTitle>

<h1>Управление БД</h1>

@if (_isLoading)
{
    <div class="alert alert-info">Загрузка...</div>
}
else if (_statistics == null)
{
    <p>Загрузка...</p>
}
else
{    
    <div>
        <h2>Статистика</h2>
        <p>В базе данных находятся <strong>@_statistics.PostTotalCount</strong> постов пользователей, написанных ими в период с <strong>@(_statistics.PostMinDate?.ToString("yyyy-MM-dd") ?? "Нет данных")</strong> по <strong>@(_statistics.PostMaxDate?.ToString("yyyy-MM-dd") ?? "Нет данных")</strong></p>
        <p></p>
        <p>В базе данных находятся <strong>@_statistics.EvaluationTotalCount</strong> оценок постов пользователей</p>
        <p></p>
        <p>Индекс страха и жадности построен с <strong>@(_statistics.IndexMinDate?.ToString("yyyy-MM-dd") ?? "Нет данных")</strong> по <strong>@(_statistics.IndexMaxDate?.ToString("yyyy-MM-dd") ?? "Нет данных")</strong></p>
    </div>
    <div>
        <h2>Управление</h2>
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Дата начала:</label>
                <input type="datetime-local"
                       @bind="_startDate"
                       class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Дата окончания:</label>
                <input type="datetime-local"
                       @bind="_endDate"
                       class="form-control" />
            </div>
            <button class="btn btn-primary" @onclick="HandleProcessRange">Обработать</button>
        </div>
        <div><button class="btn btn-danger" @onclick="ClearDB">Очистить БД</button></div>
    </div>        
}






@code {
    private StatisticsResult? _statistics = null;
    private DateTime? _startDate = DateTime.Now.AddDays(-7);
    private DateTime? _endDate = DateTime.Now;
    private bool _isLoading = false;

    [Inject]
    private IConfiguration? Configuration { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _statistics = await StatisticsService.GetStatisticsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки статистики: {ex.Message}");
            _statistics = new StatisticsResult();
        }
    }

    private async Task ClearDB()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            await StatisticsService.ClearDatabaseAsync();
            _statistics = await StatisticsService.GetStatisticsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при очистке БД: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleProcessRange()
    {
        if (!_startDate.HasValue || !_endDate.HasValue)
        {
            return;
        }

        _isLoading = true;
        StateHasChanged();

        try
        {
            if (Configuration is null)
            {
                Console.WriteLine("Не удалось получить конфигурацию");
                return;
            }

            // Получаем URL из конфигурации
            var schedulerUrl = Configuration["SCHEDULER_API_URL"]
                ?? "http://scheduler:8080";

            using var httpClient = new HttpClient();
            httpClient.Timeout = TimeSpan.FromHours(5);
            var startFormatted = _startDate.Value.ToUniversalTime().ToString("yyyy-MM-ddTHH:mm:ssZ");
            var endFormatted = _endDate.Value.ToUniversalTime().ToString("yyyy-MM-ddTHH:mm:ssZ");

            // Формируем полный URL
            var fullUrl = $"{schedulerUrl}/process-range?start={startFormatted}&end={endFormatted}";

            var response = await httpClient.GetAsync(fullUrl);

            if (response.IsSuccessStatusCode)
            {
                _statistics = await StatisticsService.GetStatisticsAsync();
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Ошибка API: {errorMessage}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при вызове API: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}
